create table sales (id bigint generated always as identity primary key,created_at timestamptz default now(),date text not null,cust_id text,cust_name text not null,province text not null,bill text,product text not null,dozen numeric not null default 0,price_per_doz numeric not null default 0,total numeric not null default 0,paid numeric default 0,remaining numeric default 0,cogs numeric default 0,gross_profit numeric default 0,margin numeric default 0,note text);
create table purchases (id bigint generated always as identity primary key,created_at timestamptz default now(),date text not null,supplier_id text not null,supplier_name text not null,bill text,material text not null,kg numeric not null default 0,amount_usd numeric not null default 0,usd_rate numeric not null default 68,amount_afn numeric default 0,paid_afn numeric default 0,remaining_usd numeric default 0,cost_per_kg numeric default 0,note text);
create table production (id bigint generated always as identity primary key,created_at timestamptz default now(),date text not null,worker text not null,product text not null,dozen numeric not null default 0,wage_rate numeric default 0,total_wage numeric default 0,paid_wage numeric default 0,remaining_wage numeric default 0,mat_cogs numeric default 0,note text);
create table cash_ledger (id bigint generated always as identity primary key,created_at timestamptz default now(),date text not null,category text not null,type text not null,description text,amount_in numeric default 0,amount_out numeric default 0);
create table settings (key text primary key,value text not null,updated_at timestamptz default now());
create table supplier_balances (supplier_id text primary key,supplier_name text not null,balance_usd numeric default 0,updated_at timestamptz default now());
create table mat_stock (material text primary key,total_kg numeric default 0,total_value_afn numeric default 0,avg_cost numeric default 0,updated_at timestamptz default now());
create table orders (id bigint generated always as identity primary key,created_at timestamptz default now(),date text not null,cust_id text,cust_name text not null,province text not null,status text default 'pending',note text);
create table order_items (id bigint generated always as identity primary key,order_id bigint references orders(id) on delete cascade,product text not null,dozen_ordered numeric not null default 0,dozen_delivered numeric default 0,dozen_remaining numeric default 0,status text default 'pending');
